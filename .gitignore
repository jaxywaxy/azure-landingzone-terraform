# ---------------------------------------------------------
# Terraform core
# ---------------------------------------------------------
.terraform/
terraform.tfstate
terraform.tfstate.*
crash.log

# Allow lock file to be committed
!.terraform.lock.hcl

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ---------------------------------------------------------
# Terraform environment files
# ---------------------------------------------------------
# Allow only env-specific tfvars
*.tfvars
!envs/**/terraform.tfvars

# Prevent accidental auto-loaded tfvars
terraform.auto.tfvars
*.auto.tfvars

# ---------------------------------------------------------
# Terraform plan files
# ---------------------------------------------------------
*.tfplan
plan.txt

# ---------------------------------------------------------
# Terraform module hygiene
# ---------------------------------------------------------
modules/**/.terraform/
modules/**/terraform.tfstate
modules/**/terraform.tfstate.*

# ---------------------------------------------------------
# OS / Editor junk
# ---------------------------------------------------------
.DS_Store
Thumbs.db

# VS Code
.vscode/
.history/

# ---------------------------------------------------------
# Logs / temp
# ---------------------------------------------------------
*.log
*.tmp